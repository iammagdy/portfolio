# SPA fallback for client-side routes (e.g. /devkit) on Apache hosting
# (Hostinger). Existing files and directories are served as-is; everything
# else is rewritten to index.html so the React app can handle the route.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files or directories.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Don't rewrite the API path — that's served by a separate backend.
  RewriteRule ^api/ - [L]

  # Everything else: serve the SPA shell.
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache hashed assets (Vite emits hashed filenames in /assets/).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|png|jpe?g|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html should never be cached so route changes deploy instantly.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
